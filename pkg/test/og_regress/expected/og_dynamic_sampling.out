SQL> CREATE OR REPLACE PROCEDURE insert_test_dy_1_data
  2 AS
  3     v_i INT := 1;
  4 BEGIN
  5     WHILE v_i <= 100 LOOP
  6         INSERT INTO test_dy_1 VALUES(
  7             MOD(v_i, 20),
  8             MOD(v_i, 30),
  9             MOD(v_i, 40)
 10         );
 11         IF MOD(v_i, 25) = 0 THEN
 12             COMMIT;
 13         END IF;
 14         v_i := v_i + 1;
 15     END LOOP;
 16     COMMIT;
 17 EXCEPTION
 18     WHEN OTHERS THEN
 19         ROLLBACK;
 20         RAISE;
 21 END;
 22 /

Succeed.

