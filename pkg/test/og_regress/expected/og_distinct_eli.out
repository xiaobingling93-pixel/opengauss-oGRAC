

SQL> -- =========================
SQL> -- 1 环境准备
SQL> -- =========================
SQL> 
SQL> DROP TABLE IF EXISTS t1;

Succeed.

SQL> DROP TABLE IF EXISTS t2;

Succeed.

SQL> 
SQL> CREATE TABLE t1(
  2                    id INT,
  3                    a  INT,
  4                    b  INT
  5 );

Succeed.

SQL> 
SQL> CREATE TABLE t2(
  2                    id INT,
  3                    a  INT
  4 );

Succeed.

SQL> 
SQL> INSERT INTO t1 VALUES
  2                    (1,1,10),
  3                    (2,1,10),
  4                    (3,2,20),
  5                    (4,2,20),
  6                    (5,3,30);

5 rows affected.

SQL> 
SQL> INSERT INTO t2 VALUES
  2                    (1,1),
  3                    (2,2),
  4                    (3,3);

3 rows affected.

SQL> 
SQL> 
SQL> -- =========================
SQL> -- 2 DISTINCT 可消除场景
SQL> -- =========================
SQL> 
SQL> -- Case1 基本场景
SQL> EXPLAIN
  2 SELECT DISTINCT a
  3 FROM (
  4          SELECT DISTINCT a
  5          FROM t1
  6      ) s
  7 ORDER BY a;

EXPLAIN PLAN OUTPUT                                             
----------------------------------------------------------------
-----------------------------------------------------------------------------------------------
| Id | Operation                   | Owner | Name | Rows | Cost  | StartCost | Bytes | Remark |
-----------------------------------------------------------------------------------------------
| 0  | SELECT STATEMENT            |       |      | 0    | 10008 | 0         |       |        |
| 1  |   SORT DISTINCT             |       |      | 0    | 10008 | 0         |       |        |
| 2  |       SUBSELECT             | SYS   | S    | 0    | 10000 | 0         |       |        |
| 3  |           TABLE ACCESS FULL | SYS   | T1   | 0    | 10000 | 0         |       |        |
-----------------------------------------------------------------------------------------------

8 rows fetched.

SQL> 
SQL> SELECT DISTINCT a
  2 FROM (
  3          SELECT DISTINCT a
  4          FROM t1
  5      ) s
  6 ORDER BY a;

A           
------------
