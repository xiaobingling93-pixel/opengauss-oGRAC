SQL> 
SQL> create or replace procedure batch_insert(tbl varchar, dx int, cnt int) as
  2 i int;
  3 x int;
  4 v_sql varchar(100);
  5 begin
  6     i := 0;
  7     x := 0;
  8     while i < cnt loop
  9         v_sql := 'INSERT INTO ' ||tbl|| ' VALUES(' ||x|| ',' ||x|| ',' ||x|| ')';
 10         execute immediate v_sql;
 11         i := i+1;
 12         x := x+dx;
 13     end loop;
 14     commit;
 15 end;
 16 /

Succeed.

SQL> exec batch_insert('t5', 1, 1000);

PL/SQL procedure successfully completed.

SQL> exec batch_insert('t6', 1, 1000);

PL/SQL procedure successfully completed.

