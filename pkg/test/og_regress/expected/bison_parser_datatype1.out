SQL> -- char, nchar default value 1
SQL> create table test_char1(
  2     c1 char,
  3     c2 char(10),
  4     c3 char(10 byte),
  5     c4 char(10 char),
  6     c5 nchar,
  7     c6 nchar(10)
  8 );

Succeed.

SQL> show create table test_char1;

CREATE TABLE "TEST_CHAR1"
(
  "C1" CHAR(1 BYTE),
  "C2" CHAR(10 BYTE),
  "C3" CHAR(10 BYTE),
  "C4" CHAR(10 CHAR),
  "C5" CHAR(1 CHAR),
  "C6" CHAR(10 CHAR)
)
TABLESPACE "SYSTEM"
INITRANS 0
MAXTRANS 255
PCTFREE 0
FORMAT ASF;



