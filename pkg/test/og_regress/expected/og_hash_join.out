

SQL> DROP TABLE IF EXISTS small_customers;

Succeed.

SQL> DROP TABLE IF EXISTS small_orders;

Succeed.

SQL> CREATE TABLE small_customers (customer_id INT PRIMARY KEY, customer_name VARCHAR(50), city VARCHAR(50));

Succeed.

SQL> INSERT INTO small_customers VALUES (1,'Alice','New York'),(2,'Bob','London'),(3,'Charlie','New York'),(4,'David','Paris'),(5,'Eve','Berlin');

5 rows affected.

SQL> CREATE TABLE small_orders (order_id INT PRIMARY KEY, customer_id INT, order_date DATE, amount DECIMAL(10,2), city VARCHAR(50));

Succeed.

SQL> INSERT INTO small_orders VALUES (101,1,'2024-01-15',100.00,'New York'),(102,1,'2024-01-20',200.00,'London'),(103,2,'2024-01-25',150.00,'London'),(104,3,'2024-01-30',300.00,'New York'),(105,3,'2024-02-01',250.00,'Tokyo'),(106,3,'2024-02-05',400.00,'New York'),(107,5,'2024-02-10',500.00,'Berlin'),(108,5,'2024-02-15',350.00,'Berlin');

8 rows affected.

SQL> analyze table  small_customers  compute STATISTICS;

Succeed.

SQL> analyze table  small_orders  compute STATISTICS;

Succeed.

SQL> alter system set ENABLE_NESTLOOP_JOIN=false;

Succeed.

SQL> alter system set ENABLE_HASH_JOIN=true;

Succeed.

