SQL> Declare
  2 i int;
  3 j int;
  4 k timestamp;
  5 begin
  6  i := 1;
  7 loop
  8  j := 1;
  9  loop
 10 	k := ADD_MONTHS(to_timestamp(to_char('1800-03-05 10:51:47'),'yyyy-mm-dd hh24:mi:ss'), j);
 11 	insert into  t_or_index_1 values(i, j, 100.123 + j, 'abc' || j, k);
 12 	j := j + 1;
 13  exit when j > 1000;
 14  end loop;
 15 i := i+1;
 16  exit when i>10;
 17 end loop;
 18  commit;
 19  end;
 20 /

