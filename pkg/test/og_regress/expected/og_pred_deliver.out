SQL> 
SQL> SELECT 'T01' AS t, o.id AS order_id
  2 FROM orders o
  3          JOIN customers c ON o.customer_id = c.id
  4 WHERE c.id = 1
  5 ORDER BY o.id;

T   ORDER_ID    
--- ------------
T01 1           
T01 2           

2 rows fetched.

SQL> 
SQL> SELECT 'T02' AS t, c.id AS customer_id
  2 FROM orders o
  3          JOIN customers c ON o.customer_id = c.id
  4 WHERE o.customer_id = 3
  5 ORDER BY c.id;

T   CUSTOMER_ID 
--- ------------
T02 3           

1 rows fetched.

SQL> 
SQL> SELECT 'T03' AS t, o.id AS order_id, c.id AS customer_id
  2 FROM orders o
  3          JOIN customers c  ON o.customer_id = c.id
  4          JOIN complaints m ON m.customer_id = c.id
  5 WHERE m.customer_id = 4
  6 ORDER BY o.id;

T   ORDER_ID     CUSTOMER_ID 
--- ------------ ------------
T03 5            4           

1 rows fetched.

SQL> 
SQL> SELECT 'T04' AS t, c.id AS customer_id
  2 FROM customers c
  3          LEFT JOIN orders o ON o.customer_id = c.id
  4 WHERE o.amount > 100
  5 ORDER BY c.id;

T   CUSTOMER_ID 
--- ------------
T04 1           
T04 2           
T04 3           
T04 4           

4 rows fetched.

SQL> 
SQL> SELECT 'T05' AS t, c.id AS customer_id
  2 FROM customers c
  3 WHERE c.id IN (
  4     SELECT o.customer_id
  5     FROM orders o
  6     WHERE o.status = 'OPEN' AND o.amount > 200
  7 )
  8 ORDER BY c.id;

T   CUSTOMER_ID 
--- ------------
T05 1           
T05 4           

2 rows fetched.

SQL> 
SQL> SELECT 'T06' AS t, c.id AS customer_id
  2 FROM customers c
  3 WHERE EXISTS (
  4     SELECT 1
  5     FROM orders o
  6     WHERE o.customer_id = c.id
  7       AND o.amount BETWEEN 100 AND 300
  8 )
  9 ORDER BY c.id;

T   CUSTOMER_ID 
--- ------------
T06 1           
T06 2           
T06 3           

3 rows fetched.

SQL> 
SQL> SELECT 'T07' AS t, o.id AS order_id
  2 FROM (
  3          SELECT id, customer_id FROM orders WHERE status = 'OPEN'
  4      ) o
  5          JOIN customers c ON o.customer_id = c.id
  6 WHERE c.region = 'EAST'
  7 ORDER BY o.id;

T   ORDER_ID    
--- ------------
T07 1           
T07 2           
T07 4           

3 rows fetched.

SQL> 
SQL> SELECT 'T08' AS t, o.id AS order_id
  2 FROM orders o
  3          JOIN customers c ON o.customer_id = c.id
  4 WHERE c.id = 1 OR c.id = 3
  5 ORDER BY o.id;

T   ORDER_ID    
--- ------------
T08 1           
T08 2           
T08 4           

3 rows fetched.

SQL> 
SQL> SELECT 'T09' AS t, c.id AS customer_id
  2 FROM customers c
  3          JOIN (SELECT DISTINCT customer_id FROM orders) o
  4               ON o.customer_id = c.id
  5 WHERE c.status = 'ACTIVE'
  6 ORDER BY c.id;

T   CUSTOMER_ID 
--- ------------
T09 1           
T09 3           
T09 4           

3 rows fetched.

SQL> 
SQL> SELECT 'T10' AS t, o.id AS order_id
  2 FROM customers c
  3          JOIN (SELECT * FROM orders WHERE amount > 200) o
  4               ON o.customer_id = c.id
  5 WHERE c.status = 'ACTIVE'
  6 ORDER BY o.id;

T   ORDER_ID    
--- ------------
T10 2           
T10 5           

2 rows fetched.

