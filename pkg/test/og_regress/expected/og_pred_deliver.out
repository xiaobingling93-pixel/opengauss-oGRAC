

SQL> DROP TABLE IF EXISTS order_items;

Succeed.

SQL> DROP TABLE IF EXISTS products;

Succeed.

SQL> DROP TABLE IF EXISTS orders;

Succeed.

SQL> DROP TABLE IF EXISTS customers;

Succeed.

SQL> DROP TABLE IF EXISTS complaints;

Succeed.

SQL> 
SQL> CREATE TABLE customers (
  2                            id        INT PRIMARY KEY,
  3                            name      VARCHAR(50),
  4                            region    VARCHAR(16),
  5                            status    VARCHAR(16)
  6 );

Succeed.

SQL> 
SQL> CREATE TABLE orders (
  2                         id          INT PRIMARY KEY,
  3                         customer_id INT,
  4                         amount      DECIMAL(10,2),
  5                         status      VARCHAR(16),
  6                         order_date  DATE
  7 );

Succeed.

SQL> 
SQL> CREATE TABLE products (
  2                           id       INT PRIMARY KEY,
  3                           category VARCHAR(16),
  4                           price    DECIMAL(10,2)
  5 );

Succeed.

SQL> 
SQL> CREATE TABLE order_items (
  2                              order_id   INT,
  3                              product_id INT,
  4                              quantity   INT
  5 );

Succeed.

SQL> 
SQL> CREATE TABLE complaints (
  2                             id          INT PRIMARY KEY,
  3                             customer_id INT,
  4                             severity    INT
  5 );

Succeed.

