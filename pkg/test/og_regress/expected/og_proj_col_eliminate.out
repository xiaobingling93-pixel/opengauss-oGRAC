SQL> -- test case_cond + winsort
SQL> select id,c_int from
  2     (select a.id,a.id+a.c_int c_int,
  3             case when (lag(a.c_int,0,null) OVER(PARTITION BY a.id,a.c_int order by a.id) +100)*10 >250
  4                      then lag(a.c_int,0,null) OVER(PARTITION BY a.id,a.c_int order by a.id)
  5                  else lag(a.c_int,0,null) OVER(PARTITION BY a.id,a.c_int order by a.id)
  6                 end
  7      from t_proj_over_limit a limit 10) order by 1,2;

ID           C_INT               
------------ --------------------
1            1                   
2            3                   
3            5                   
4            7                   
5            9                   
6            11                  
7            13                  
8            15                  
9            17                  
10           19                  

