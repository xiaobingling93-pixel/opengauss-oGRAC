

SQL> DROP TRIGGER IF EXISTS insert_readonly_view;

Succeed.

SQL> DROP TRIGGER IF EXISTS update_readonly_view;

Succeed.

SQL> DROP TRIGGER IF EXISTS delete_readonly_view;

Succeed.

SQL> 
SQL> DROP VIEW IF EXISTS read_only_view;

Succeed.

SQL> 
SQL> DROP TABLE IF EXISTS test_table;

Succeed.

SQL> 
SQL> CREATE TABLE test_table (
  2                             id INT PRIMARY KEY,
  3                             name VARCHAR(50),
  4                             age INT
  5 );

Succeed.

SQL> 
SQL> INSERT INTO test_table VALUES (1, '张三', 25);

1 rows affected.

SQL> INSERT INTO test_table VALUES (2, '李四', 30);

1 rows affected.

SQL> INSERT INTO test_table VALUES (3, '王五', 28);

1 rows affected.

SQL> 
SQL> CREATE VIEW read_only_view WITH READ ONLY AS
  2 SELECT id, name, age FROM test_table;

Succeed.

SQL> 
SQL> SELECT * FROM read_only_view;

ID           NAME                                               AGE         
------------ -------------------------------------------------- ------------
1            张三                                             25          
2            李四                                             30          
3            王五                                             28          

3 rows fetched.

SQL> 
SQL> INSERT INTO read_only_view VALUES (5, '钱七', 40);

OG-00601, [1:13]Sql syntax error: view operation INSERT must based on instead of trigger but current view has no trigger
SQL> 
SQL> UPDATE read_only_view SET age = 31 WHERE id = 2;

OG-00601, [1:8]Sql syntax error: view operation UPDATE must based on instead of trigger but current view has no trigger
SQL> 
SQL> DELETE FROM read_only_view WHERE id = 2;

OG-00601, [1:13]Sql syntax error: view operation DELETE must based on instead of trigger but current view has no trigger
SQL> 
SQL> SELECT * FROM test_table;

ID           NAME                                               AGE         
------------ -------------------------------------------------- ------------
1            张三                                             25          
2            李四                                             30          
3            王五                                             28          

3 rows fetched.

SQL> 
SQL> DROP VIEW read_only_view;

Succeed.

SQL> 
SQL> DROP TABLE test_table;
Succeed.




