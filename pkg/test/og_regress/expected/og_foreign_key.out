

SQL> -- foreign key constraint self
SQL> drop table if exists t_emp;

Succeed.

SQL> create table t_emp (empno number(4), mgr number(4), ename varchar2(10));

Succeed.

SQL> alter table t_emp add constraint t_emp_pk primary key(empno);

Succeed.

SQL> alter table t_emp add constraint t_emp_fk foreign key(mgr) references t_emp(empno);

Succeed.

SQL> insert into t_emp values (0,null,'root');

1 rows affected.

SQL> insert into t_emp (empno,mgr) values (1,0);

1 rows affected.

SQL> insert into t_emp (empno,mgr) values (2,1);

1 rows affected.

SQL> insert into t_emp (empno,mgr) values (3,2);

1 rows affected.

SQL> commit;

Succeed.

SQL> -- insert error
SQL> insert into t_emp (empno,mgr) values (10,23);

OG-01128, Integrity constraint violated - parent key not found
SQL> insert into t_emp (empno,mgr) values (5,4);

OG-01128, Integrity constraint violated - parent key not found
SQL> -- update
SQL> update t_emp set mgr = 11 where empno = 3;   -- error

OG-01128, Integrity constraint violated - parent key not found
SQL> update t_emp set mgr = null where empno = 3; -- success

1 rows affected.

SQL> update t_emp set mgr = 3 where empno = 0;    -- success

1 rows affected.

SQL> commit;

Succeed.

SQL> insert into  t_emp values (-1,null,'oGRAC'); -- success

1 rows affected.

SQL> commit;

Succeed.

SQL> delete from t_emp where empno = 1; -- error

OG-01123, The row is referenced by child record
SQL> delete from t_emp where empno = -1; -- success

1 rows affected.

SQL> commit;

Succeed.

SQL> drop table t_emp;

Succeed.

SQL> 
SQL> -- drop referenced primary key should fail
SQL> drop table if exists emp;

Succeed.

SQL> drop table if exists dept;

Succeed.

SQL> create table dept(deptno number(2), dname varchar2(20), constraint deptno_id primary key(deptno));

Succeed.

SQL> create table emp(empno number(4) primary key, ename varchar2(20), deptno number(2));

Succeed.

SQL> alter table emp add constraint emp_deptno_fk foreign key(deptno) references dept(deptno);

Succeed.

SQL> 
SQL> insert into dept values(10, 'Test');

1 rows affected.

SQL> insert into dept values(20, 'Develop');

1 rows affected.

SQL> insert into dept values(30, 'HR');

1 rows affected.

SQL> insert into dept values(40, 'Sales');

1 rows affected.

SQL> insert into dept values(50, 'Finance');

1 rows affected.

SQL> 
SQL> insert into emp values(0001, 'Nancy', 10);

1 rows affected.

SQL> insert into emp values(0002, 'Tom', 10);

1 rows affected.

SQL> insert into emp values(0003, 'Anne', 20);

1 rows affected.

SQL> insert into emp values(0004, 'Alice', 30);

1 rows affected.

SQL> insert into emp values(0005, 'Gaby', 40);

1 rows affected.

SQL> insert into emp values(0006, 'Lynette', 30);

1 rows affected.

SQL> 
SQL> alter table dept drop constraint deptno_id;

OG-00847, This unique/primary key is referenced by some foreign keys
SQL> 
SQL> drop table emp;

Succeed.

SQL> drop table dept;

Succeed.

