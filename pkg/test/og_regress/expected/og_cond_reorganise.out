

SQL> -- ==========================================
SQL> -- 1. Environment Setup (DDL)
SQL> -- ==========================================
SQL> 
SQL> -- Drop tables if they exist
SQL> DROP TABLE IF EXISTS t_opt_order;

Succeed.

SQL> DROP TABLE IF EXISTS t_opt_customer;

Succeed.

SQL> 
SQL> -- Create Customer Table
SQL> CREATE TABLE t_opt_customer (
  2     cust_id INT PRIMARY KEY,
  3     name VARCHAR(50),
  4     region VARCHAR(20),
  5     credit_score INT
  6 );

Succeed.

SQL> 
SQL> -- Create Order Table
SQL> CREATE TABLE t_opt_order (
  2     order_id INT PRIMARY KEY,
  3     cust_id INT,
  4     amount DECIMAL(10, 2),
  5     order_date DATE,
  6     status VARCHAR(20)
  7 );

Succeed.

SQL> 
SQL> -- Create Indexes to support optimization
SQL> -- Region index for filtering
SQL> CREATE INDEX idx_cust_region ON t_opt_customer(region);

Succeed.

SQL> -- Foreign key index (implicit or explicit usually good for joins)
SQL> CREATE INDEX idx_order_cust ON t_opt_order(cust_id);

Succeed.

SQL> 
